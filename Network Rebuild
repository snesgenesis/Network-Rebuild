#!/usr/bin/env bash

set -e

echo "===== Centegix Network Rebuild ====="

# Go to gateway directory
cd /home/centegix/gateway || {
    echo "Failed to change directory"
    exit 1
}

echo "Stopping all forever processes..."
forever stopall

run_rebuild() {
    WAIT_TIME=$1

    echo "Starting rebuild_network.js"
    node scripts/rebuild_network.js &
    NODE_PID=$!

    echo "Waiting $WAIT_TIME seconds..."
    sleep "$WAIT_TIME"

    echo "Sending Ctrl+C to node process..."
    kill -SIGINT $NODE_PID

    wait $NODE_PID 2>/dev/null || true
}

# Run rebuild cycles
run_rebuild 5
run_rebuild 5
run_rebuild 5
run_rebuild 15

echo "Restarting gateway service..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever --minUptime 1 start /home/centegix/gateway/index.js

echo "Following logs..."
forever logs 0 -f
