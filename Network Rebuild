#!/usr/bin/env bash

set -e

echo "===== Centegix Zigbee Network Rebuild ====="

# Go to gateway directory
cd /home/centegix/gateway || exit 1

echo "Stopping gateway services..."
forever stopall || true

run_rebuild () {

    WAIT=$1

    echo ""
    echo "Running rebuild_network.js (wait ${WAIT}s)..."

    node "$REBUILD_SCRIPT" &
    PID=$!

    sleep "$WAIT"

    echo "Stopping rebuild process (PID $PID)"
    kill -SIGINT "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true
}

# Run rebuild cycles
run_rebuild 12
run_rebuild 12
run_rebuild 12
run_rebuild 45

echo ""
echo "Restarting gateway service..."

sudo -u centegix forever --minUptime 1 start "$GATEWAY_DIR/index.js"

echo ""
echo "Following logs..."
forever logs 0 -f
