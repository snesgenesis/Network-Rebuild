#bash script.sh

set -e

echo "===== Centegix Network Rebuild ====="

cd /home/centegix/gateway || exit 1

echo "Stopping all forever processes..."
forever stopall || true

run_rebuild() {

    echo "Starting rebuild cycle 1"
    node scripts/rebuild_network.js &
    PID=$!
    sleep 10
    kill -SIGINT "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true

    echo "Starting rebuild cycle 2"
    node scripts/rebuild_network.js &
    PID=$!
    sleep 10
    kill -SIGINT "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true

    echo "Starting rebuild cycle 3"
    node scripts/rebuild_network.js &
    PID=$!
    sleep 10
    kill -SIGINT "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true
}

# Run rebuild procedure
run_rebuild

echo "Restarting gateway service..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever --minUptime 1 start /home/centegix/gateway/index.js

echo "Following logs..."
forever logs 0 -f
