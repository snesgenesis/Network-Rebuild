#!/usr/bin/env bash

set -euo pipefail

LOGFILE="/var/log/centegix-network-rebuild.log"
LOCKFILE="/tmp/centegix_rebuild.lock"
GATEWAY_DIR="/home/centegix/gateway"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOGFILE"
}

cleanup() {
    rm -f "$LOCKFILE"
}
trap cleanup EXIT

# Prevent multiple runs
if [ -f "$LOCKFILE" ]; then
    echo "Script already running."
    exit 1
fi
touch "$LOCKFILE"

log "===== Centegix Network Rebuild Started ====="

# Verify required commands exist
for cmd in node forever sudo; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        log "ERROR: $cmd not installed"
        exit 1
    fi
done

# Change directory
cd "$GATEWAY_DIR" || {
    log "ERROR: Cannot access $GATEWAY_DIR"
    exit 1
}

log "Stopping all forever processes..."
forever stopall || true

run_rebuild() {

    for i in 1 2 3
    do
        log "Starting rebuild cycle $i"

        node scripts/rebuild_network.js &
        PID=$!

        sleep 10

        log "Stopping rebuild process (PID $PID)"
        kill -SIGINT "$PID" 2>/dev/null || true
        wait "$PID" 2>/dev/null || true
    done
}

run_rebuild

log "Restarting gateway service..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever --minUptime 1 start "$GATEWAY_DIR/index.js"

log "Gateway service restarted"

log "Following logs..."
forever logs 0 -f
