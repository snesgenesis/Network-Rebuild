#!/usr/bin/env bash

set -e

echo ""
echo "===== Centegix Network Rebuild ====="
echo ""

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Step 0: Hostname and time
HOST=$(uname -a)
log "Running on $HOST"

# Step 1: Shutdown Zigbee network
shutdown_zigbee() {

    log "Step 1: Shutdown Zigbee network"

    GATEWAY_DIR="/home/centegix/gateway"

    cd "$GATEWAY_DIR" || {
        echo "Failed to change directory"
        exit 1
    }

    echo ""
