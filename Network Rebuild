#!/usr/bin/env bash

set -e

echo ""
echo "===== Centegix Network Rebuild ====="
echo ""

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

# Step 0: Hostname and time
HOST=$(uname -a)
log "Running on $HOST"

# Step 1: Shutdown Zigbee network
shutdown_zigbee() {

    log "Step 1: Shutdown Zigbee network"

    GATEWAY_DIR="gateway"

    if [ ! -d "$GATEWAY_DIR" ]; then
        log "ERROR: Gateway directory not found: $GATEWAY_DIR"
        exit 1
    fi

    cd "$GATEWAY_DIR"

    log "Changed directory to $GATEWAY_DIR"

    # Example shutdown command placeholder
    # ./shutdown_zigbee.sh

    log "Zigbee shutdown step complete"
}

shutdown_zigbee

echo ""
log "=== Network rebuild script complete ==="
echo ""
