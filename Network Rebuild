#!/usr/bin/env bash

set -e

GATEWAY_DIR="/home/centegix/gateway"
REBUILD_SCRIPT="scripts/rebuild_network.js"

echo "===== Centegix Zigbee Network Rebuild ====="

# Verify directory exists
if [ ! -d "$GATEWAY_DIR" ]; then
    echo "ERROR: Gateway directory not found: $GATEWAY_DIR"
    exit 1
fi

cd "$GATEWAY_DIR"

echo "Stopping gateway services..."
forever stopall || true

run_rebuild () {

    WAIT=$1

    echo ""
    echo "Running rebuild_network.js (wait ${WAIT}s)..."

    node "$REBUILD_SCRIPT" &
    PID=$!

    sleep "$WAIT"

    echo "Stopping rebuild process (PID $PID)"
    kill -SIGINT "$PID" 2>/dev/null || true
    wait "$PID" 2>/dev/null || true
}

# Run rebuild cycles
run_rebuild 12
run_rebuild 12
run_rebuild 12
run_rebuild 45

echo ""
echo "Restarting gateway service..."

sudo -u centegix FOREVER_ROOT=/tmp/forever \
forever --minUptime 1 start /home/centegix/gateway/index.js

echo ""
echo "Following logs..."
forever logs 0 -f
